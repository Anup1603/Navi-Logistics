# ─── Zoho Mail SMTP Configuration ────────────────────────────────────
# Copy this file to .env and replace the placeholder values with your
# Zoho Mail App-Specific Password.
#
# Generate an App Password at:
#   https://accounts.zoho.com/home#security/app_password
#
# Use the exact outgoing server shown in Zoho Mail → Settings →
# Mail Accounts → Outgoing Server for your account.
# ─────────────────────────────────────────────────────────────────────

# SMTP server credentials
SMTP_USER=contact@navilogistics.in
SMTP_PASS=your_zoho_app_password_here
SMTP_HOST=smtppro.zoho.in
SMTP_PORT=465
SMTP_SECURE=true
# Optional: leave unset unless your mailbox provider requires it.
# SMTP_AUTH_METHOD=LOGIN

# Email identities (sender and recipient)
EMAIL_FROM=contact@navilogistics.in
EMAIL_FROM_NAME=Navi Logistics
EMAIL_TO=contact@navilogistics.in
