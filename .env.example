# Email Configuration for Contact Form
# Copy this file to .env and replace the placeholder values with your Zoho Mail SMTP credentials.
# Use the exact outgoing server shown in Zoho Mail Server Configuration for your account.

EMAIL_USER=contact@navilogistics.in
EMAIL_PASS=your_zoho_app_password_here
SMTP_USER=contact@navilogistics.in
SMTP_PASS=your_zoho_app_password_here
EMAIL_FROM=contact@navilogistics.in
EMAIL_FROM_NAME=Navi Logistics
EMAIL_TO=contact@navilogistics.in
SMTP_HOST=smtppro.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_AUTH_METHOD=LOGIN
